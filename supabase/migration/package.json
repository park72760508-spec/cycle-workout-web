{
  "name": "stelvio-firestore-to-supabase",
  "version": "1.0.0",
  "private": true,
  "description": "Firestore → Supabase PostgreSQL bulk migration",
  "type": "module",
  "scripts": {
    "setup:env": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')){fs.copyFileSync('.env.example','.env'); console.log('Created .env — edit DATABASE_URL password');} else {console.log('.env already exists');}\"",
    "migrate": "tsx migrateData.ts",
    "migrate:dry": "tsx migrateData.ts --dry-run",
    "migrate:auth": "tsx migrateAuthUsers.ts",
    "migrate:auth:dry": "tsx migrateAuthUsers.ts --dry-run",
    "test:db": "tsx scripts/testDbConnection.ts",
    "count:rides": "tsx scripts/countRides.ts",
    "schema:riding-groups": "tsx scripts/ensureRidingGroupsSchema.ts",
    "migrate:riding-groups": "tsx scripts/migrateRidingGroupsAndMedia.ts",
    "verify:riding-groups": "tsx scripts/verifyRidingGroupsBackfill.ts",
    "sync:group-members": "tsx scripts/syncRidingGroupMembersBackfill.ts",
    "sync:peak-rank-snapshots": "tsx scripts/syncPeakRankSnapshotsBackfill.ts",
    "sync:peak-rank-snapshots:dry": "tsx scripts/syncPeakRankSnapshotsBackfill.ts --dry-run",
    "sync:user-gender": "tsx scripts/syncUserGenderBackfill.ts",
    "sync:user-gender:dry": "tsx scripts/syncUserGenderBackfill.ts --dry-run",
    "sync:user-gender:refresh": "tsx scripts/syncUserGenderBackfill.ts --refresh-mv",
    "rebuild:heptagon": "tsx scripts/rebuildHeptagonCohortRanks.ts",
    "verify:rankings": "node ../../scripts/compare-ranking-firestore-supabase.mjs",
    "verify:phase2": "tsx scripts/verifyPhase2E2E.ts",
    "verify:phase2:sample": "tsx scripts/verifyPhase2E2E.ts --sample=100",
    "backfill:yearly-peaks": "tsx scripts/backfillYearlyPeaksFromRides.ts",
    "backfill:yearly-peaks:dry": "tsx scripts/backfillYearlyPeaksFromRides.ts --dry-run",
    "verify:phase4": "tsx scripts/verifyPhase4GoNoGo.ts",
    "monitor:firestore-commits": "tsx scripts/monitorFirestoreCommits.ts",
    "remote-config:full": "tsx scripts/setDualWriteRemoteConfig.ts --status=FULL"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "@supabase/supabase-js": "^2.49.1",
    "firebase-admin": "^12.7.0",
    "pg": "^8.13.1",
    "pg-copy-streams": "^6.0.6",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@types/pg-copy-streams": "^1.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
