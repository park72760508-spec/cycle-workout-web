{
  "name": "stelvio-firestore-to-supabase",
  "version": "1.0.0",
  "private": true,
  "description": "Firestore → Supabase PostgreSQL bulk migration",
  "type": "module",
  "scripts": {
    "setup:env": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')){fs.copyFileSync('.env.example','.env'); console.log('Created .env — edit DATABASE_URL password');} else {console.log('.env already exists');}\"",
    "migrate": "tsx migrateData.ts",
    "migrate:dry": "tsx migrateData.ts --dry-run",
    "migrate:auth": "tsx migrateAuthUsers.ts",
    "migrate:auth:dry": "tsx migrateAuthUsers.ts --dry-run",
    "test:db": "tsx scripts/testDbConnection.ts",
    "verify:rankings": "node ../../scripts/compare-ranking-firestore-supabase.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "@supabase/supabase-js": "^2.49.1",
    "firebase-admin": "^12.7.0",
    "pg": "^8.13.1",
    "pg-copy-streams": "^6.0.6",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@types/pg-copy-streams": "^1.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
