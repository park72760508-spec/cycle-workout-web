// Firebase Storage Rules — firebase deploy --only storage
// 상세·CORS: docs/storage.rules 주석 참고

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function stelvioRidingGroupCoverActor(groupId) {
      return request.auth != null
        && (
          (
            firestore.exists(/databases/(default)/documents/stelvio_riding_groups/$(groupId))
            && firestore.get(/databases/(default)/documents/stelvio_riding_groups/$(groupId)).data.createdBy == request.auth.uid
          )
          || (
            firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
            && (
              firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.grade == '1'
              || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.grade == 1
            )
          )
        );
    }

    match /open_riding_gpx/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 12 * 1024 * 1024
        && (
          request.resource.contentType == 'application/gpx+xml'
          || request.resource.contentType == 'text/xml'
          || request.resource.contentType == 'application/xml'
        );
    }

    match /stelvio_riding_groups/{groupId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && (
        (
          request.resource != null
          && request.resource.size < 2 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
          && stelvioRidingGroupCoverActor(groupId)
        )
        || (request.resource == null && stelvioRidingGroupCoverActor(groupId))
      );
    }

    match /affiliates/{affiliateId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.contentType.matches('image/.*')
        && (
          (fileName.matches('cover_.*\\.jpg') && request.resource.size < 2  * 1024 * 1024)
          || (fileName.matches('promo_.*\\.jpg') && request.resource.size < 10 * 1024 * 1024)
          || request.resource.size < 5 * 1024 * 1024
        );
    }

    match /profile_images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && (fileName == request.auth.uid + '_profile.webp'
            || fileName == request.auth.uid + '_profile.jpg')
        && request.resource.size < 512 * 1024
        && (request.resource.contentType == 'image/webp'
            || request.resource.contentType == 'image/jpeg');
    }

    match /{path=**} {
      allow read: if true;
      allow write: if request.auth != null
        && !path.matches('^open_riding_gpx(/.*)?$')
        && !path.matches('^profile_images(/.*)?$')
        && !path.matches('^stelvio_riding_groups(/.*)?$')
        && !path.matches('^affiliates(/.*)?$');
    }
  }
}
